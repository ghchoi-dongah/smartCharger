<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout  xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="800dp"
    android:layout_height="380dp"
    tools:context=".pages.AuthSelectFragment">

    <!-- member info -->
    <View
        android:id="@+id/viewMember"
        android:layout_width="370dp"
        android:layout_height="360dp"
        android:layout_marginStart="20dp"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/layer_list_rect_corner"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textViewMember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/memberMessage"
        android:textSize="30sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/viewMember"
        app:layout_constraintStart_toStartOf="@id/viewMember"
        app:layout_constraintEnd_toEndOf="@id/viewMember" />

    <ImageView
        android:id="@+id/imageViewMember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/member"
        app:layout_constraintTop_toBottomOf="@id/textViewMember"
        app:layout_constraintStart_toStartOf="@id/viewMember"
        app:layout_constraintEnd_toEndOf="@id/viewMember"
        tools:ignore="contentDescription" />

    <TextView
        android:id="@+id/textViewMemberContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="70dp"
        android:text="@string/memberInfoMessage"
        android:textSize="25sp"
        app:layout_constraintStart_toStartOf="@id/viewMember"
        app:layout_constraintEnd_toEndOf="@id/viewMember"
        app:layout_constraintTop_toBottomOf="@id/imageViewMember" />

    <TextView
        android:id="@+id/textViewMemberUnitInput"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="충전단가: 280원"
        android:textSize="22sp"
        app:layout_constraintStart_toStartOf="@id/imageViewMember"
        app:layout_constraintTop_toBottomOf="@id/imageViewMember"
        app:layout_constraintEnd_toEndOf="@id/imageViewMember" />

    <!-- nomember info -->
    <View
        android:id="@+id/viewNoMember"
        android:layout_width="370dp"
        android:layout_height="360dp"
        android:layout_marginEnd="20dp"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/layer_list_rect_corner"
        app:layout_constraintTop_toTopOf="@id/viewMember"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/textViewNoMember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/nomemberMessage"
        android:textSize="30sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/viewNoMember"
        app:layout_constraintStart_toStartOf="@id/viewNoMember"
        app:layout_constraintEnd_toEndOf="@id/viewNoMember" />

    <ImageView
        android:id="@+id/imageViewNoMember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/nomember"
        app:layout_constraintTop_toBottomOf="@id/textViewNoMember"
        app:layout_constraintStart_toStartOf="@id/viewNoMember"
        app:layout_constraintEnd_toEndOf="@id/viewNoMember"
        tools:ignore="contentDescription" />

    <TextView
        android:id="@+id/textViewNoMemberContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="70dp"
        android:text="@string/nomemberInfoMessage"
        android:textSize="25sp"
        app:layout_constraintStart_toStartOf="@id/viewNoMember"
        app:layout_constraintEnd_toEndOf="@id/viewNoMember"
        app:layout_constraintTop_toBottomOf="@id/imageViewNoMember" />

    <TextView
        android:id="@+id/textViewNoMemberUnitInput"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="충전단가: 480원"
        android:textSize="22sp"
        app:layout_constraintStart_toStartOf="@id/imageViewNoMember"
        app:layout_constraintTop_toBottomOf="@id/imageViewNoMember"
        app:layout_constraintEnd_toEndOf="@id/imageViewNoMember" />

</androidx.constraintlayout.widget.ConstraintLayout >